<!--
  WXSG (WPF XAML Source Generator) — C# Expressions Demo
  ========================================================

  This project uses WpfXsgEnabled=true in sample.csproj.
  The source generator (XamlToCSharpGenerator.Generator.WPF) produces:

    1. Typed field declarations for every x:Name element below
       (e.g. "internal System.Windows.Controls.TextBox FirstNameBox;")
    2. InitializeComponent() that calls Application.LoadComponent + FindName
       for each named element (Phase 1 / BAML-hybrid behaviour)

  WPF's MSBuild-generated .g.cs is suppressed; the WXSG output wins instead.
  Inspect obj/<tfm>/<AssemblyName>.<file>.wpf.g.cs to see the generated code.

  WXSG Phase 5 goal (not yet implemented):
    Inline C# expressions replace boilerplate converters and multi-bindings, e.g.

      Text="{cs: vm.FirstName + " " + vm.LastName}"
      Visibility="{cs: vm.Items.Count > 0 ? Visibility.Visible : Visibility.Collapsed}"
      Background="{cs: vm.IsValid ? Brushes.LightGreen : Brushes.LightCoral}"

    WXSG compiles those expressions into the generated InitializeComponent —
    zero reflection, zero IValueConverter, full IDE rename/refactoring support.
-->
<Window x:Class="sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sample"
        mc:Ignorable="d"
        Title="WXSG — C# Expressions Demo"
        Width="520"
        Height="420">

  <Window.Resources>
    <local:GreetingViewModel x:Key="Vm" />
  </Window.Resources>

  <Grid DataContext="{StaticResource Vm}" Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Greeting header — Phase 5: Text="{cs: $"Hello, {vm.FullName}!"}" -->
    <TextBlock x:Name="GreetingLabel"
               Grid.Row="0"
               FontSize="22"
               FontWeight="SemiBold"
               Margin="0,0,0,16"
               Text="{Binding Greeting}" />

    <!-- Name editor -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="80" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="80" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Grid.Column="0" Content="First:" VerticalAlignment="Center" />
      <TextBox x:Name="FirstNameBox"
               Grid.Column="1"
               Margin="4,0"
               Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />

      <Label Grid.Column="2" Content="Last:" VerticalAlignment="Center" />
      <TextBox x:Name="LastNameBox"
               Grid.Column="3"
               Margin="4,0"
               Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>

    <!-- Full name read-back — Phase 5: Text="{cs: vm.FirstName + " " + vm.LastName}" -->
    <TextBlock x:Name="FullNameLabel"
               Grid.Row="2"
               Margin="0,0,0,12"
               Foreground="Gray"
               Text="{Binding FullName}" />

    <!-- Items list -->
    <ListBox x:Name="ItemsList"
             Grid.Row="3"
             Margin="0,0,0,8"
             ItemsSource="{Binding Items}" />

    <!-- Add item row -->
    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBox x:Name="NewItemBox"
               Grid.Column="0"
               Margin="0,0,8,0"
               Text="{Binding NewItem, UpdateSourceTrigger=PropertyChanged}" />

      <Button x:Name="AddButton"
              Grid.Column="1"
              Padding="12,4"
              Content="Add"
              Click="AddButton_Click" />
    </Grid>
  </Grid>
</Window>
