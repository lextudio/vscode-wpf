<!--
  WXSG sample:
  - Simpler XAML: no explicit xmlns declarations at file head.
  - C# expressions: `{cs: ...}` values are emitted as direct C# in WXSG output.
-->
<Window x:Class="sample.MainWindow"
        Title="{cs: string.Concat(&quot;WXSG — &quot;, &quot;C# Expressions + Simpler XAML&quot;)}"
        Width="{cs: 520}"
        Height="{cs: 420}">

  <Window.Resources>
    <local:GreetingViewModel x:Key="Vm" />
  </Window.Resources>

  <Grid DataContext="{StaticResource Vm}" Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Greeting header — Phase 5: Text="{cs: $"Hello, {vm.FullName}!"}" -->
    <TextBlock x:Name="GreetingLabel"
               Grid.Row="0"
               FontSize="22"
               FontWeight="SemiBold"
               Margin="0,0,0,16"
               Text="{Binding Greeting}" />

    <!-- Name editor -->
    <Grid Grid.Row="1" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="80" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="80" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Label Grid.Column="0" Content="First:" VerticalAlignment="Center" />
      <TextBox x:Name="FirstNameBox"
               Grid.Column="1"
               Margin="4,0"
               Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />

      <Label Grid.Column="2" Content="Last:" VerticalAlignment="Center" />
      <TextBox x:Name="LastNameBox"
               Grid.Column="3"
               Margin="4,0"
               Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
    </Grid>

    <!-- Full name read-back — Phase 5: Text="{cs: vm.FirstName + " " + vm.LastName}" -->
    <TextBlock x:Name="FullNameLabel"
               Grid.Row="2"
               Margin="0,0,0,12"
               Foreground="Gray"
               Text="{cs: string.Concat(&quot;Computed label: &quot;, &quot;full name below&quot;)}" />

    <!-- Items list -->
    <ListBox x:Name="ItemsList"
             Grid.Row="3"
             Margin="0,0,0,8"
             ItemsSource="{Binding Items}" />

    <!-- Add item row -->
    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBox x:Name="NewItemBox"
               Grid.Column="0"
               Margin="0,0,8,0"
               Text="{Binding NewItem, UpdateSourceTrigger=PropertyChanged}" />

      <Button x:Name="AddButton"
              Grid.Column="1"
              Padding="12,4"
              Content="{cs: string.Concat(&quot;Add&quot;, &quot; Item&quot;)}"
              Click="AddButton_Click" />
    </Grid>
  </Grid>
</Window>
