<!--
  WXSG — C# Expressions Demo
  ===========================
  Every value below is computed by a {cs: ...} expression compiled directly
  into InitializeComponent(). No IValueConverter. No code-behind. No reflection.

  What {cs: ...} replaces in each case is noted inline.
-->
<Window x:Class="sample.MainWindow"
        Title="WXSG C# Expressions"
        Width="500"
        Height="520"
        Background="White">

  <StackPanel Margin="24">

    <!-- Title: string interpolation instead of code-behind setter -->
    <TextBlock FontSize="20" FontWeight="Bold" Margin="0,0,0,4"
               Text="{cs: $&quot;Running on {(IntPtr.Size == 8 ? &quot;64-bit&quot; : &quot;32-bit&quot;)} .NET&quot;}" />

    <!-- Subtitle: replaces a code-behind line in constructor -->
    <TextBlock Foreground="Gray" FontSize="12" Margin="0,0,0,20"
               Text="{cs: System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription}" />

    <!-- ── Section 1: String expressions ─────────────────────────────────── -->
    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"
               Text="String expressions" />

    <Border Background="#F8F8F8" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="28" />
          <RowDefinition Height="28" />
          <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="User" />
        <!-- replaces: tb.Text = Environment.UserName; in constructor -->
        <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: Environment.UserName}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="Machine" />
        <!-- replaces: tb.Text = Environment.MachineName; -->
        <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: Environment.MachineName}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="CPU Cores" />
        <!-- replaces: tb.Text = $"{Environment.ProcessorCount} logical"; in constructor -->
        <TextBlock Grid.Row="2" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: $&quot;{Environment.ProcessorCount} logical&quot;}" />
      </Grid>
    </Border>

    <!-- ── Section 2: Conditional expressions ────────────────────────────── -->
    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"
               Text="Conditional expressions — replaces BoolToStringConverter" />

    <Border Background="#F8F8F8" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="28" />
          <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="Elevated" />
        <!-- replaces: new BoolToStringConverter("Yes","No") -->
        <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Foreground="{cs: System.Security.Principal.WindowsIdentity.GetCurrent().Owner?.IsWellKnown(System.Security.Principal.WellKnownSidType.BuiltinAdministratorsSid) == true ? System.Windows.Media.Brushes.DarkRed : System.Windows.Media.Brushes.DarkGreen}"
                   Text="{cs: System.Security.Principal.WindowsIdentity.GetCurrent().Owner?.IsWellKnown(System.Security.Principal.WellKnownSidType.BuiltinAdministratorsSid) == true ? &quot;Yes — Admin&quot; : &quot;No — Standard&quot;}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="Interactive" />
        <!-- replaces: bool → string in code-behind -->
        <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: Environment.UserInteractive ? &quot;Yes&quot; : &quot;No&quot;}" />
      </Grid>
    </Border>

    <!-- ── Section 3: Math expressions ──────────────────────────────────── -->
    <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"
               Text="Math expressions — replaces static resource + converter" />

    <Border Background="#F8F8F8" CornerRadius="6" Padding="14,10" Margin="0,0,0,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="150" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="28" />
          <RowDefinition Height="28" />
          <RowDefinition Height="28" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="π" />
        <TextBlock Grid.Row="0" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: Math.PI.ToString(&quot;F10&quot;)}" />

        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="e" />
        <TextBlock Grid.Row="1" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: Math.E.ToString(&quot;F10&quot;)}" />

        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="#666" VerticalAlignment="Center"
                   Text="φ (golden)" />
        <TextBlock Grid.Row="2" Grid.Column="1" FontFamily="Consolas" VerticalAlignment="Center"
                   Text="{cs: ((1.0 + Math.Sqrt(5.0)) / 2.0).ToString(&quot;F10&quot;)}" />
      </Grid>
    </Border>

    <!-- Footer: timestamp computed at build/init time -->
    <TextBlock FontSize="10" Foreground="#AAAAAA" TextAlignment="Right"
               Text="{cs: $&quot;Initialized {DateTime.Now:HH:mm:ss} — zero IValueConverter, zero reflection&quot;}" />

  </StackPanel>
</Window>
