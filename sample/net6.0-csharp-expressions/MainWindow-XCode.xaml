<!--
  WXSG x:Code Demo
  ================
  Demonstrates inline C# code blocks in XAML using x:Code.

  The code in the <x:Code> block becomes part of the generated partial class.
  This enables event handlers and helper methods to be defined directly in XAML.
-->
<Window x:Class="sample.MainWindowXCode"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="x:Code Demo"
        Width="500"
        Height="350"
        Background="White">

  <!--
    x:Code block: contains C# statements that become part of the partial class body.
    This is compiled directly into the generated code-behind.
  -->
  <x:Code>
    <![CDATA[
    private int _clickCount = 0;

    private void OnButtonClick(object sender, RoutedEventArgs e)
    {
        _clickCount++;
        CounterLabel.Content = $"Button clicked {_clickCount} time{(_clickCount != 1 ? "s" : "")}";
        ClickHistoryTextBlock.Text += $"{System.DateTime.Now:HH:mm:ss} - Click #{_clickCount}\n";
    }

    private void OnClearClick(object sender, RoutedEventArgs e)
    {
        _clickCount = 0;
        CounterLabel.Content = "Click the button to start";
        ClickHistoryTextBlock.Text = string.Empty;
    }
    ]]>
  </x:Code>

  <Grid Margin="24">
    <StackPanel VerticalAlignment="Top">
      <!-- Title -->
      <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,12"
                 Text="x:Code Demo — Event Handlers in XAML" />

      <!-- Description -->
      <TextBlock FontSize="12" Foreground="#666" Margin="0,0,0,16"
                 TextWrapping="Wrap"
                 Text="The event handlers below (OnButtonClick, OnClearClick) are defined in the x:Code block above. They become part of the generated partial class without any code-behind file." />

      <!-- Counter Section -->
      <Border Background="#F0F8FF" CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
        <StackPanel>
          <TextBlock FontSize="11" Foreground="#666" Margin="0,0,0,4"
                     Text="Click Counter" />
          <TextBlock x:Name="CounterLabel" FontSize="24" FontWeight="Bold" FontFamily="Consolas"
                     Text="Click the button to start" />
        </StackPanel>
      </Border>

      <!-- Button Section -->
      <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
        <Button Click="OnButtonClick" Padding="12,8" Margin="0,0,8,0"
                Background="#4CAF50" Foreground="White" FontWeight="SemiBold"
                Content="Increment" />
        <Button Click="OnClearClick" Padding="12,8"
                Background="#FF9800" Foreground="White" FontWeight="SemiBold"
                Content="Reset" />
      </StackPanel>

      <!-- History Section -->
      <TextBlock FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"
                 Text="Click History" />
      <Border Background="#F8F8F8" CornerRadius="4" BorderBrush="#DDD" BorderThickness="1"
              Padding="8" Height="120" Margin="0,0,0,0">
        <ScrollViewer>
          <TextBlock x:Name="ClickHistoryTextBlock" FontFamily="Consolas" FontSize="10"
                     Foreground="#333" TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>
    </StackPanel>
  </Grid>
</Window>
