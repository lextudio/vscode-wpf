{
  "name": "vscode-wpf",
  "displayName": "VS Code Tools for WPF",
  "description": "VS Code extension for WPF (.xaml) files with visual designer integration.",
  "version": "0.9.5",
  "publisher": "lextudio",
  "engines": {
    "vscode": "^1.101.0"
  },
  "extensionDependencies": [
    "ms-dotnettools.vscode-dotnet-runtime"
  ],
  "os": [
    "win32"
  ],
  "activationEvents": [
    "onView:wpf.toolbox",
    "onLanguage:xaml",
    "onCommand:wpf.launchDesigner",
    "onCommand:wpf.previewXaml",
    "onCommand:wpf.hotReload",
    "onCommand:wpf.rebuildRestartDesigner",
    "onCommand:wpf.selectProject",
    "onCommand:wpf.openXamlFile",
    "onCommand:wpf.buildDesignerTools"
  ],
  "main": "out/extension.js",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/lextudio/vscode-wpf.git"
  },
  "bugs": {
    "url": "https://github.com/lextudio/vscode-wpf/issues"
  },
  "homepage": "https://github.com/lextudio/vscode-wpf#readme",
  "license": "MIT",
  "author": "LeXtudio",
  "categories": [
    "Other"
  ],
  "keywords": [
    "wpf",
    "xaml",
    "designer"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "compile:tests": "tsc -p test/tsconfig.json",
    "watch": "tsc -w -p .",
    "build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js --sourcemap",
    "watch:build": "esbuild src/extension.ts --bundle --platform=node --external:vscode --outfile=out/extension.js --sourcemap --watch",
    "test:integration:hotreload": "npm run build && npm run compile:tests && node ./test/runTest.js",
    "build-designer": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/build-designer.ps1",
    "package:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./dist.windows.ps1",
    "package:publish:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./dist.windows.ps1 -Publish",
    "publish:marketplace": "powershell -NoProfile -ExecutionPolicy Bypass -File ./publish.ps1",
    "version:git": "powershell -NoProfile -ExecutionPolicy Bypass -File ./update-version.ps1",
    "version:gitversion": "powershell -NoProfile -ExecutionPolicy Bypass -File ./update-version.ps1"
  },
  "contributes": {
    "commands": [
      {
        "command": "wpf.launchDesigner",
        "title": "WPF: Launch Designer",
        "icon": {
          "light": "images/designer.svg",
          "dark": "images/designer.svg"
        }
      },
      {
        "command": "wpf.hotReload",
        "title": "WPF: Hot Reload",
        "icon": {
          "light": "images/hot-reload.svg",
          "dark": "images/hot-reload.svg"
        }
      },
      {
        "command": "wpf.rebuildRestartDesigner",
        "title": "WPF: Rebuild and Restart Designer"
      },
      {
        "command": "wpf.selectProject",
        "title": "WPF: Select Project"
      },
      {
        "command": "wpf.openXamlFile",
        "title": "WPF: Open XAML File"
      },
      {
        "command": "wpf.buildDesignerTools",
        "title": "WPF: Build Designer Tools"
      }
    ],
    "languages": [
      {
        "id": "xaml",
        "aliases": [
          "XAML"
        ],
        "extensions": [
          ".xaml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "wpf.hotReload",
          "when": "resourceExtname == .xaml",
          "group": "navigation"
        },
        {
          "command": "wpf.launchDesigner",
          "when": "resourceExtname == .xaml",
          "group": "navigation@1"
        }
      ],
      "explorer/context": [
        {
          "command": "wpf.openXamlFile",
          "when": "resourceExtname == .csproj",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "wpf.hotReload"
        },
        {
          "command": "wpf.launchDesigner"
        },
        {
          "command": "wpf.rebuildRestartDesigner"
        },
        {
          "command": "wpf.selectProject"
        },
        {
          "command": "wpf.openXamlFile"
        },
        {
          "command": "wpf.buildDesignerTools"
        }
      ]
    },
    "views": {
      "wpf": [
        {
          "type": "webview",
          "id": "wpf.toolbox",
          "name": "WPF Toolbox"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "wpf",
          "title": "WPF",
          "icon": "images/activitybar.svg"
        }
      ]
    },
    "configuration": {
      "title": "WPF Designer",
      "properties": {
        "wpf.designerExecutable": {
          "type": "string",
          "default": "",
          "description": "Override path to XamlDesigner.exe. Leave empty to use the bundled designer."
        },
        "wpf.dotnetPath": {
          "type": "string",
          "default": "dotnet",
          "description": "Path to the dotnet CLI executable used for building projects."
        },
        "wpf.autoBuildOnDesignerLaunch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically build the project before launching the visual designer."
        },
        "wpf.autoBuildOnPreview": {
          "type": "boolean",
          "default": true,
          "description": "Deprecated. Use wpf.autoBuildOnDesignerLaunch.",
          "deprecationMessage": "Use wpf.autoBuildOnDesignerLaunch instead."
        },
        "wpf.designerSyncOnEdit": {
          "type": "boolean",
          "default": true,
          "description": "When a designer session is already running, push XAML editor changes into it automatically without rebuilding."
        },
        "wpf.runtimeHotReloadOnEdit": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for automatic runtime hot reload on edit. The current runtime hot reload flow is push-based from the Hot Reload command."
        },
        "wpf.liveRuntimeOnEdit": {
          "type": "boolean",
          "default": false,
          "description": "Deprecated. Use wpf.runtimeHotReloadOnEdit.",
          "deprecationMessage": "Use wpf.runtimeHotReloadOnEdit instead."
        },
        "wpf.buildConfiguration": {
          "type": "string",
          "default": "Debug",
          "description": "MSBuild configuration used when building the WPF project (e.g. Debug, Release)."
        },
        "wpf.designerTargetFramework": {
          "type": "string",
          "default": "",
          "description": "Target framework used when building the XamlDesigner tool. Leave empty to auto-detect the highest .NET SDK installed on this machine (recommended). Override only when you need to pin to a specific version, e.g. net10.0-windows."
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.76.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.18.11",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "vscode-languageclient": "^9.0.1"
  }
}
